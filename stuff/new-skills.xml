	<element name="Society" type="Magic Item" source="Laurence Stuff" id="ID_LAURENCE_ITEM_SOCIETY">
		<description><p>Grants the Society feature.</p></description>
		<setters><set name="category">New Skills</set><set name="type">New Skill</set><set name="cost">0</set><set name="weight">0 lb.</set><set name="slot">misc</set><set name="attunement">false</set><set name="rarity">Common</set></setters>
		<rules><grant type="Feat" id="ID_LAURENCE_FEAT_SOCIETY" /></rules>
	</element>

	<element name="Society" type="Feat" source="Laurence Stuff" id="ID_LAURENCE_FEAT_SOCIETY">
		<description><p>Society represents knowledge of current affairs. It is based on Intelligence.</p></description>
		<sheet><description>Society: {{society:skill}}. Uses Intelligence.</description></sheet>
		<rules><stat name="society:skill" value="intelligence:modifier" /></rules>
	</element>

	<element name="Society Proficiency" type="Magic Item" source="Laurence Stuff" id="ID_LAURENCE_ITEM_SOCIETY_PROFICIENCY">
		<description><p>Grants the Society Proficiency feature.</p></description>
		<setters><set name="category">New Skills</set><set name="type">New Skill</set><set name="cost">0</set><set name="weight">0 lb.</set><set name="slot">misc</set><set name="attunement">false</set><set name="rarity">Common</set></setters>
		<rules><grant type="Feat" id="ID_LAURENCE_FEAT_SOCIETY_PROFICIENCY" /></rules>
	</element>

	<element name="Society Proficiency" type="Feat" source="Laurence Stuff" id="ID_LAURENCE_FEAT_SOCIETY_PROFICIENCY">
		<description><p>Society represents knowledge of current affairs. You are proficient in Society.</p></description>
		<sheet><description>Society: {{society:skill}}. Uses Intelligence + Proficiency Bonus.</description></sheet>
		<rules><stat name="society:skill" value="intelligence:modifier" /><stat name="society:skill" value="proficiency" /></rules>
	</element>

