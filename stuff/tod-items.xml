<?xml version="1.0" encoding="utf-8"?>
<elements>

	<info>
		<name>ToD Items</name>
		<description>Custom magic items and equipment.</description>
		<author>B B</author>
		<update version="1.0.7">
			<file name="tod-items.xml" url="https://raw.githubusercontent.com/esmer-1/Talents-and-stuff/refs/heads/main/stuff/tod-items.xml" />
		</update>
	</info>

	<element name="Illusionist's Gloves" type="Magic Item" source="Laurence Stuff" id="ID_TOD_ITEM_ILLUSIONISTS_GLOVES_V2">
		<description>
			<p><strong>Wondrous Item, uncommon (requires attunement)</strong></p>
			<p>While wearing these gloves, when you cast an illusion spell that has both verbal and somatic components, you can ignore the verbal component of the spell.</p>
			<p>This benefit applies only if the spell requires a somatic component. Material components are unaffected.</p>
		</description>
		<setters>
			<set name="category">ToD Items</set>
			<set name="type">ToD Item</set>
			<set name="slot">hands</set>
			<set name="rarity">Uncommon</set>
			<set name="attunement">true</set>
			<set name="cost">0</set>
			<set name="weight">0 lb.</set>
		</setters>
	</element>

		<element name="Light Shield" type="Armor" source="Laurence Stuff" id="ID_LAURENCE_GEAR_LIGHT_SHIELD">
	<supports>ID_INTERNAL_ARMOR_GROUP_SHIELD</supports>
	<description>
		<p>A small and lightweight shield. Wielding this shield increases your Armor Class by 1.</p>
		<p>A Light Shield is small and light enough that it only takes a bonus action to don or doff, and counts as a free hand for some purposes, but not for casting spells or wielding weapons in two hands.</p>
	</description>
	<setters>
		<set name="category">Armor</set>
		<set name="cost" currency="gp">10</set>
		<set name="weight" lb="2">2 lb.</set>
		<set name="slot">onehand,secondary</set>
		<set name="type">Shield</set>
		<set name="armor">Shield</set>
		<set name="armorClass">+1</set>
		<set name="proficiency">ID_PROFICIENCY_ARMOR_PROFICIENCY_SHIELD</set>
	</setters>
	<rules>
		<stat name="ac:shield" value="1" bonus="shield" />
	</rules>
</element>

<element name="Standard Shield" type="Armor" source="Laurence Stuff" id="ID_LAURENCE_GEAR_STANDARD_SHIELD">
	<supports>ID_INTERNAL_ARMOR_GROUP_SHIELD</supports>
	<description>
		<p>A standard shield. Wielding this shield increases your Armor Class by 2.</p>
	</description>
	<setters>
		<set name="category">Armor</set>
		<set name="cost" currency="gp">70</set>
		<set name="weight" lb="6">6 lb.</set>
		<set name="slot">onehand,secondary</set>
		<set name="type">Shield</set>
		<set name="armor">Shield</set>
		<set name="armorClass">+2</set>
		<set name="proficiency">ID_PROFICIENCY_ARMOR_PROFICIENCY_SHIELD</set>
	</setters>
	<rules>
		<stat name="ac:shield" value="2" bonus="shield" />
	</rules>
</element>

<element name="Heavy Shield" type="Armor" source="Laurence Stuff" id="ID_LAURENCE_GEAR_HEAVY_SHIELD">
	<supports>ID_INTERNAL_ARMOR_GROUP_SHIELD</supports>
	<description>
		<p>A large reinforced shield. Wielding this shield increases your Armor Class by 3.</p>
		<p>You must have a Strength score of 13 or higher to use this shield effectively.</p>
	</description>
	<setters>
		<set name="category">Armor</set>
		<set name="cost" currency="gp">500</set>
		<set name="weight" lb="12">12 lb.</set>
		<set name="slot">onehand,secondary</set>
		<set name="type">Shield</set>
		<set name="armor">Shield</set>
		<set name="strength">13</set>
		<set name="armorClass">+3</set>
		<set name="proficiency">ID_PROFICIENCY_ARMOR_PROFICIENCY_SHIELD</set>
	</setters>
	<rules>
		<stat name="ac:shield" value="3" bonus="shield" />
		<stat name="speed" value="-10" bonus="armor" requirements="!([str:13]||ID_INTERNAL_GRANT_ARMOR_IGNORE_STRENGTH_REQUIREMENT)" />
	</rules>
</element>
</elements>
