<?xml version="1.0" encoding="utf-8"?>
<elements>

	<info>
		<name>Raka's Talents</name>
		<description>Custom talents for Raka.</description>
		<author>B B</author>
		<update version="1.0.1">
			<file name="raka-talents.xml" url="https://raw.githubusercontent.com/esmer-1/Talents-and-stuff/refs/heads/main/talents/raka/raka-talents.xml" />
		</update>
	</info>

	<element name="Resolute" type="Magic Item" source="Laurence Stuff" id="ID_RAKAS_TALENTS_ITEM_RESOLUTE">
		<description><p>Grants the Resolute talent.</p></description>
		<setters>
			<set name="category">Talents</set>
			<set name="type">Talent</set>
			<set name="slot">misc</set>
			<set name="rarity">Common</set>
			<set name="attunement">false</set>
			<set name="cost">0</set>
			<set name="weight">0 lb.</set>
		</setters>
		<rules>
			<grant type="Feat" id="ID_RAKAS_TALENTS_FEAT_RESOLUTE" />
		</rules>
	</element>

	<element name="Resolute" type="Feat" source="Laurence Stuff" id="ID_RAKAS_TALENTS_FEAT_RESOLUTE">
		<description>
			<p>When below half of your maximum hit points, you gain advantage on Strength, Dexterity, and Constitution saving throws.</p>
		</description>
		<sheet>
			<description>While below half your maximum hit points, you have advantage on Strength, Dexterity, and Constitution saving throws.</description>
		</sheet>
	</element>

	<element name="Life Spell Adept" type="Magic Item" source="Laurence Stuff" id="ID_RAKAS_TALENTS_ITEM_LIFE_SPELL_ADEPT">
		<description><p>Grants the Life Spell Adept talent.</p></description>
		<setters>
			<set name="category">Talents</set>
			<set name="type">Talent</set>
			<set name="slot">misc</set>
			<set name="rarity">Common</set>
			<set name="attunement">false</set>
			<set name="cost">0</set>
			<set name="weight">0 lb.</set>
		</setters>
		<rules>
			<grant type="Feat" id="ID_RAKAS_TALENTS_FEAT_LIFE_SPELL_ADEPT" />
		</rules>
	</element>

	<element name="Life Spell Adept" type="Feat" source="Laurence Stuff" id="ID_RAKAS_TALENTS_FEAT_LIFE_SPELL_ADEPT">
		<description>
			<p>Once per long rest, you can cast an Abjuration or Restoration spell that you don't have prepared. This costs a spell slot as usual.</p>
		</description>
		<sheet usage="1/Long Rest">
			<description>Cast one unprepared Abjuration or Restoration spell, expending a spell slot as normal.</description>
		</sheet>
	</element>

</elements>
